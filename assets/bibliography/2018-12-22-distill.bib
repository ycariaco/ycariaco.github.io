	keywords = {Adult, Female, Humans, Pregnancy, Ovulation Induction, oocyte quality, controlled ovarian stimulation, embryo quality, Embryo Transfer, endometrioma, endometriosis, Endometriosis, Endometrium, Fertilization in Vitro, Gynecologic Surgical Procedures, Infertility, Female, IVF outcome, Ovarian Reserve},
	pages = {633--641},
	file = {Full Text:/Users/yusmariscariaco/Zotero/storage/4W3L32S4/Polat et al. - 2015 - In vitro fertilization for endometriosis-associated infertility.pdf:application/pdf},
}


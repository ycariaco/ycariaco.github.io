	keywords = {Female, Humans, Pregnancy, Placenta, Cohort Studies, Maternal-Fetal Exchange, Maternal Exposure, Biopsy, Permeability, Air Pollutants, Ecotoxicology, Belgium, Microscopy, Electron, Transmission, Residence Characteristics, Soot},
	pages = {3866},
	file = {Full Text:/Users/yusmariscariaco/Zotero/storage/D8PPBHUA/Bové et al. - 2019 - Ambient black carbon particles reach the fetal side of human placenta.pdf:application/pdf},

	keywords = {Female, Humans, Pregnancy, Pregnancy Complications, Retrospective Studies, Infant, Newborn, Body Mass Index, Case-Control Studies, Birth Weight, Body Composition, Obesity, Morbid, Perinatal Mortality, Pregnancy, High-Risk, Spain, Thinness},
	pages = {308--312},
}


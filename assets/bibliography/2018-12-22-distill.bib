	pages = {463--469},
	file = {Full Text:/Users/yusmariscariaco/Zotero/storage/FDAF64R7/Luo et al. - 2021 - Characteristics and Pregnancy Outcomes of Asymptomatic and Symptomatic Women with COVID-19 Lessons.pdf:application/pdf},
